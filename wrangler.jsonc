{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aoki-clinic",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-04",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
